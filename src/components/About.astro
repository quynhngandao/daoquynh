---
const skills = [
  'TypeScript',
  'React',
  'Next.js',
  'Astro',
  'Node.js',
  'PostgreSQL',
  'Docker',
  'Git',
  'Python',
  'REST APIs',
  'CI/CD',
  'AWS',
];
---

<section id="about" class="mx-auto max-w-5xl px-6 py-24">
  <h2 class="mb-12 text-3xl font-bold text-gray-50">About me</h2>

  <div class="grid gap-12 md:grid-cols-2">
    <div class="body-text space-y-4 leading-relaxed text-gray-400">
      <p>
        I'm a software engineer who loves crafting clean, performant products that delight users. I
        care deeply about code quality, developer experience, and shipping things that matter.
      </p>
      <p>
        When I'm not coding I enjoy hiking, reading, and exploring new coffee shops. I'm always
        happy to chat about technology, design, or your next big idea.
      </p>
      <a
        href="/resume.pdf"
        class="text-brand-500 hover:text-brand-400 inline-flex items-center gap-2 text-sm transition-colors"
      >
        Download résumé
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
      </a>
    </div>

    <div>
      <h3 class="mb-4 text-sm font-semibold uppercase tracking-widest text-gray-500">
        Technologies
      </h3>
      <ul class="flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <li class="rounded-md border border-gray-800 bg-gray-900 px-3 py-1 font-mono text-xs text-gray-300">
              {skill}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
