<section
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 pt-20 text-center"
>
  <p class="hero-intro text-brand-500 mb-4">Hi, I'm</p>

  <h1 class="hero-bg-name text-gray-50">Quynh</h1>

  <p class="hero-role relative z-10 mb-6 text-gray-50">Software Engineer</p>

  <p class="body-text relative z-10 mb-10 max-w-prose leading-relaxed text-gray-400">
    I build thoughtful web experiences and enjoy exploring the intersection of engineering and
    design. Currently open to new opportunities.
  </p>

  <div class="relative z-10 flex flex-wrap items-center justify-center gap-4">
    <a
      href="#projects"
      class="btn bg-brand-600 hover:bg-brand-500 rounded-lg px-6 py-3 text-white shadow-lg transition-colors"
    >
      View my work
    </a>
    <a
      href="#contact"
      class="btn rounded-lg border border-gray-700 px-6 py-3 text-gray-300 transition-colors hover:border-gray-500 hover:text-gray-100"
    >
      Get in touch
    </a>
  </div>

  <!-- scroll cue -->
  <a
    href="#about"
    class="absolute bottom-10 z-10 animate-bounce text-gray-600 transition-colors hover:text-gray-400"
    aria-label="Scroll down"
  >
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </a>
</section>
