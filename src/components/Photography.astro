---
import '@/styles/photography.css';

const totalPhotos = 86;
const photos = Array.from({ length: totalPhotos }, (_, i) => {
  const num = String(i + 1).padStart(3, '0');
  return { src: `/assets/photograph/photo-${num}.jpg`, alt: `Photo ${i + 1}` };
});
---

<section id="photography" class="relative px-4 py-24 md:px-6 md:py-28">
  <div class="mx-auto w-full space-y-10">
    <h2
      class="text-center text-xl font-extrabold uppercase tracking-widest sm:text-2xl lg:text-3xl"
      style="color: #04285f"
    >
      Captured Through My
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="inline-block h-6 w-6 align-middle sm:h-7 sm:w-7 lg:h-8 lg:w-8"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path
          d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"
        ></path>
        <circle cx="12" cy="13" r="3"></circle>
      </svg>
    </h2>

    <div id="photo-grid" class="photo-masonry">
      {
        photos.map((photo, i) => (
          <div class:list={['photo-item', i >= 20 && 'hidden']} data-photo-index={i}>
            <button
              class="photo-trigger group relative block w-full cursor-zoom-in"
              data-src={photo.src}
              data-alt={photo.alt}
              aria-label={`View ${photo.alt} fullscreen`}
            >
              <img
                src={photo.src}
                alt={photo.alt}
                loading="lazy"
                decoding="async"
                class="ring-white/20 w-full rounded-xl shadow-lg ring-1 transition-transform duration-300 group-hover:scale-[1.02]"
              />
              <span class="pointer-events-none absolute right-2 top-2 rounded-full bg-black/40 p-1.5 opacity-0 backdrop-blur-sm transition-opacity duration-200 group-hover:opacity-100">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 text-white"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </span>
            </button>
          </div>
        ))
      }
    </div>

    <div id="load-more-wrap" class="flex justify-center">
      <button
        id="load-more-btn"
        class="border-white/25 bg-white/10 hover:bg-white/20 rounded-full border px-5 py-2 text-xs font-semibold text-white backdrop-blur-sm transition-all hover:-translate-y-0.5 sm:px-8 sm:py-3 sm:text-sm"
      >
        Load more
      </button>
    </div>
  </div>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label="Photo lightbox"
  >
    <div class="relative">
      <button
        id="lightbox-close"
        class="absolute right-2 top-2 z-10 rounded-full bg-black/40 p-1.5 text-white backdrop-blur-sm transition-colors hover:bg-black/60"
        aria-label="Close"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="max-h-[90vh] max-w-[90vw] rounded-xl object-contain shadow-2xl"
      />
    </div>
  </div>

  <a
    href="#contact"
    class="absolute inset-x-0 bottom-8 flex animate-bounce justify-center text-[#04285f]/60 transition-colors hover:text-[#04285f]"
    aria-label="Next section"
  >
    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </a>
</section>

<script>
  const BATCH = 20;
  let shown = 20;
  const items = document.querySelectorAll<HTMLElement>('#photo-grid .photo-item');
  const btn = document.getElementById('load-more-btn')!;
  const wrap = document.getElementById('load-more-wrap')!;

  function showMore() {
    const next = Math.min(shown + BATCH, items.length);
    for (let i = shown; i < next; i++) {
      items[i].classList.remove('hidden');
    }
    shown = next;
    if (shown >= items.length) {
      wrap.classList.add('hidden');
    }
  }

  btn.addEventListener('click', showMore);

  // Hide button if ≤20 photos
  if (items.length <= 20) {
    wrap.classList.add('hidden');
  }

  // Lightbox
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close')!;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.photo-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      openLightbox(trigger.dataset.src!, trigger.dataset.alt!);
    });
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
