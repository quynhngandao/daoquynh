---
interface Project {
  title: string;
  description: string;
  tech: string[];
  href?: string;
  repo?: string;
}

const projects: Project[] = [
  {
    title: 'Project Alpha',
    description:
      'A full-stack web application that does something impressive. Built with modern tooling and deployed to the cloud.',
    tech: ['Next.js', 'TypeScript', 'PostgreSQL', 'Tailwind'],
    href: 'https://example.com',
    repo: 'https://github.com/daoquynh/project-alpha',
  },
  {
    title: 'Project Beta',
    description:
      'An open-source tool that solves a real developer pain point. Hundreds of weekly downloads on npm.',
    tech: ['Node.js', 'TypeScript', 'CLI'],
    repo: 'https://github.com/daoquynh/project-beta',
  },
  {
    title: 'Project Gamma',
    description:
      'An API service powering a mobile app with real-time features and advanced caching strategies.',
    tech: ['Python', 'FastAPI', 'Redis', 'Docker'],
    href: 'https://example.com',
    repo: 'https://github.com/daoquynh/project-gamma',
  },
];
---

<section id="projects" class="bg-gray-900/40 py-24">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="mb-12 text-3xl font-bold text-gray-50">Projects</h2>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map(({ title, description, tech, href, repo }) => (
          <article class="flex flex-col rounded-xl border border-gray-800 bg-gray-900 p-6 transition-colors hover:border-gray-700">
            <div class="mb-4 flex items-start justify-between">
              <h3 class="text-lg font-semibold text-gray-100">{title}</h3>
              <div class="ml-2 flex shrink-0 gap-3">
                {repo && (
                  <a
                    href={repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="GitHub repository"
                    class="text-gray-500 transition-colors hover:text-gray-300"
                  >
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.73.084-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z" />
                    </svg>
                  </a>
                )}
                {href && (
                  <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Live site"
                    class="text-gray-500 transition-colors hover:text-gray-300"
                  >
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                )}
              </div>
            </div>

            <p class="mb-4 flex-1 text-sm leading-relaxed text-gray-400">{description}</p>

            <ul class="flex flex-wrap gap-2">
              {tech.map((t) => (
                <li class="text-brand-400 bg-brand-900/20 rounded px-2 py-0.5 font-mono text-xs">
                  {t}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
