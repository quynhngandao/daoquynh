---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import Footer from '@/components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <Hero />

    <section id="about" class="flex min-h-screen items-center justify-center bg-amber-950">
      <h2 class="text-4xl font-bold text-amber-200">about me page</h2>
    </section>

    <section id="project" class="flex min-h-screen items-center justify-center bg-indigo-950">
      <h2 class="text-4xl font-bold text-indigo-200">project page</h2>
    </section>

    <section id="experience" class="flex min-h-screen items-center justify-center bg-emerald-950">
      <h2 class="text-4xl font-bold text-emerald-200">experience page</h2>
    </section>

    <section id="photography" class="flex min-h-screen items-center justify-center bg-rose-950">
      <h2 class="text-4xl font-bold text-rose-200">photography page</h2>
    </section>

    <section id="contact" class="flex min-h-screen items-center justify-center bg-violet-950">
      <h2 class="text-4xl font-bold text-violet-200">contact me page</h2>
    </section>
  </main>
  <Footer />
</Layout>
